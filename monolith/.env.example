NODE_ENV=development
PORT=4000
MONGO_URI=mongodb://localhost:27017
REDIS_URL=redis://localhost:6379
INTERNAL_API_KEY=dev-internal-key-change-in-production
JWT_PRIVATE_KEY=dev-private-key-change-in-production
JWT_PUBLIC_KEY=dev-public-key-change-in-production
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
FMCSA_API_KEY=your-fmcsa-key
NOMINATIM_API_URL=https://nominatim.openstreetmap.org
NHTSA_VIN_API_URL=https://vpic.nhtsa.dot.gov/api

# SMTP Email Configuration
# Works with any SMTP provider: Mailtrap, Gmail, SendGrid, AWS SES, etc.
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_FROM_EMAIL=noreply@flow-logistics.com
SMTP_FROM_NAME=FLOW Logistics

# Frontend URL (used in email links)
FRONTEND_URL=http://localhost:3001
