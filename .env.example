# ==========================================
# FLOW Backend - EC2 IP Deployment Environment
# ==========================================
# Place this file at: /home/ubuntu/flow-backend/.env
#
# Setup: Single EC2 instance, no domain, raw IP access
# Jenkins runs on SAME EC2 instance (port 8080)
# Gateway API: http://EC2_IP:3000
# Realtime WS: http://EC2_IP:3005
# ==========================================

NODE_ENV=production

# ==========================================
# SHARED SECRETS
# ==========================================

# Internal API key for gateway <-> monolith communication
# Generate: openssl rand -hex 32
INTERNAL_API_KEY=change-me-to-a-long-random-string-minimum-32-chars

# JWT Secret for token signing (symmetric HS256)
# MUST be identical in monolith and realtime
# Generate: openssl rand -base64 64
JWT_SECRET=change-me-to-a-long-random-secret-minimum-64-chars

# CORS origins - your EC2 public IP + Vercel domain (when you have one)
# Format: http://EC2_IP:3000,http://EC2_IP:3001,https://your-vercel-app.vercel.app
# For now with just EC2 IP: http://YOUR_EC2_IP:3001 (frontend port)
# Use * for development (not recommended for production)
CORS_ORIGINS=*

# ==========================================
# MONOLITH
# ==========================================

# Docker-internal MongoDB URL
MONGO_URI=mongodb://mongodb:27017

# Docker-internal Redis URL
REDIS_URL=redis://redis:6379

# Cloudinary for file uploads
# Get from: https://cloudinary.com/console
# Format: cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# FMCSA API (optional - leave empty if not using)
FMCSA_API_KEY=

# External APIs (defaults are fine, only change if needed)
NOMINATIM_API_URL=https://nominatim.openstreetmap.org
NHTSA_VIN_API_URL=https://vpic.nhtsa.dot.gov/api

# ==========================================
# SMTP Email Configuration
# ==========================================
# Works with any SMTP provider: Mailtrap, Gmail, SendGrid, AWS SES, etc.
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_FROM_EMAIL=noreply@flow-logistics.com
SMTP_FROM_NAME=FLOW Logistics

# Frontend URL (used in email links like team invites)
FRONTEND_URL=http://localhost:3001
